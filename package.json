{
  "name": "dubex",
  "version": "0.0.1",
  "description": "A JavaScript and TypeScript CLI toolkit for generating boilerplate, accessors, and backend resources.",
  "type": "module",
  "bin": {
    "dbx": "./dist/bin/cli.js"
  },
  "scripts": {
    "build": "tsc && chmod +x dist/bin/cli.js",
    "check": "tsc --noEmit",
    "dev": "node bin/cli.ts",
    "dev:accessors": "node bin/cli.ts gen accessors",
    "start": "node dist/bin/cli.js",
    "link:global": "pnpm build && pnpm add -g ."
  },
  "keywords": [
    "cli",
    "toolkit",
    "codegen",
    "generator",
    "scaffolding",
    "boilerplate",
    "javascript",
    "typescript",
    "node",
    "express",
    "mongoose",
    "mongodb",
    "accessors",
    "getters",
    "setters"
  ],
  "author": "Mason J. Dubelbeis",
  "license": "ISC",
  "devEngines": {
    "packageManager": {
      "name": "pnpm",
      "version": "11.1.3",
      "onFail": "download"
    }
  },
  "devDependencies": {
    "@types/node": "^25.9.1",
    "eslint": "^10.4.0",
    "typescript": "^6.0.3"
  },
  "dependencies": {
    "commander": "^14.0.3"
  }
}